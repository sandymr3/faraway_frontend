# ── SwarmResQ Frontend — environment variables ───────────────────────────────
# Copy to .env.local for local dev, or set in your hosting provider's dashboard.
# NEXT_PUBLIC_ prefix makes the var available in the browser bundle.

# URL of the SwarmResQ backend WebSocket/HTTP server.
# Local dev:   http://localhost:8000
# Hosted:      https://your-backend.railway.app  (or Render/Fly/etc.)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
